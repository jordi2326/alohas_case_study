# Streamlit Cloud → Settings → Secrets
#
# OPTION A — No service account (recommended for public deploy)
# Add this single line under Advanced settings → Environment variables instead:
#   DASHBOARD_DATA_SOURCE=cache
# Then commit dashboard/cache/*.parquet (generate locally: python dashboard/export_cache.py)
#
# OPTION B — Live BigQuery (requires GCP service account)
# [gcp_service_account]
# type = "service_account"
# project_id = "alohas-recruiting-study-case"
# private_key_id = "..."
# private_key = "-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# client_email = "..."
# client_id = "..."
# auth_uri = "https://accounts.google.com/o/oauth2/auth"
# token_uri = "https://oauth2.googleapis.com/token"
# auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
# client_x509_cert_url = "..."
#
# DASHBOARD_DATA_SOURCE = "bq"
